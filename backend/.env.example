# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
# Local dev matches the docker-compose.yml postgres service below.
DATABASE_URL=postgresql+psycopg2://planner:planner@localhost:5432/planner

# --- App ---
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Aurora Importer (used starting Phase 3) ---
AURORA_BASE_URL=https://aurora.umanitoba.ca/StudentRegistrationSsb/ssb
AURORA_REQUEST_DELAY_SECONDS=0.5
